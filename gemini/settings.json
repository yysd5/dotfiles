{
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "mcpServers": {
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    }
  },
  "general": {
    "preferredEditor": "vim",
    "previewFeatures": true,
    "vimMode": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "ANSI",
    "footer": {
      "hideContextPercentage": false
    },
    "showLineNumbers": false
  },
  "experimental": {
    "plan": true,
    "enableAgents": true
  }
}