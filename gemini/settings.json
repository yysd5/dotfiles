{
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "general": {
    "preferredEditor": "vim",
    "previewFeatures": true,
    "vimMode": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    },
    "enableAutoUpdate": true,
    "plan": {
      "enabled": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "ANSI",
    "footer": {
      "hideContextPercentage": false
    },
    "showLineNumbers": false
  },
  "experimental": {
    "enableAgents": true,
    "contextManagement": true
  },
  "agents": {
    "overrides": {}
  },
  "telemetry": {
    "enabled": true,
    "target": "gcp",
    "useCliAuth": true,
    "logPrompts": true
  }
}